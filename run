#!/usr/bin/env bash

set -euo pipefail

if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
  cat <<'USAGE'
Usage: ./run

Starts local development stack:
- PostgreSQL (Docker Compose)
- Backend (FastAPI + Uvicorn, autoreload)
- Web admin (Next.js dev server)
- CodeGraphContext watcher (auto reindex on file changes)

After startup, prints localhost + LAN URLs for browser access.

Environment overrides:
- BACKEND_HOST (default: 127.0.0.1)
- BACKEND_PORT (default: 8000)
- WEB_HOST (default: 127.0.0.1)
- WEB_PORT (default: 3000)
- WEB_DIR_NAME (default: web-admin if present, otherwise web)
- CGC_WATCH (default: 1, set 0 to disable)
- CGC_DATABASE (default: falkordb)
- CGC_WATCH_PATH (default: project root)
- CGC_LOG_FILE (default: .run/codegraph-watch.log)
- KG_MEMORY_SYNC (default: 1, set 0 to disable auto sync)
- KG_MEMORY_SYNC_MODE (default: auto, values: auto|force)
- KG_MEMORY_FILE (default: .context/operations/kg_memory.jsonl)
- AUTO_INSTALL_BACKEND_DEPS (default: 1, set 0 to disable auto pip install)
- AUTO_FIX_BROKEN_DB_SCHEMA (default: 1, auto-repair schema on inconsistency)
- ALLOW_DB_SCHEMA_RESET (default: 1, allows DROP SCHEMA public in auto-repair)
- CONFIRM_DB_RESET (default: YES_I_UNDERSTAND_DATA_LOSS)
- DB_BACKUP_BEFORE_DESTRUCTIVE (default: 1, set 0 to skip backup before destructive reset)
- DB_BACKUP_DIR (default: .backups/db)
- HEALTH_POLL_INTERVAL (default: 10, seconds between post-start health checks)
USAGE
  exit 0
fi

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
BACKEND_DIR="$ROOT_DIR/backend"
WEB_DIR_NAME="${WEB_DIR_NAME:-}"
if [[ -z "$WEB_DIR_NAME" ]]; then
  if [[ -d "$ROOT_DIR/web-admin" ]]; then
    WEB_DIR_NAME="web-admin"
  else
    WEB_DIR_NAME="web"
  fi
fi
WEB_DIR="$ROOT_DIR/$WEB_DIR_NAME"
COMPOSE_FILE="$ROOT_DIR/docker-compose.yml"
STATE_DIR="$ROOT_DIR/.run"
BACKEND_PID_FILE="$STATE_DIR/backend.pid"
WEB_PID_FILE="$STATE_DIR/web.pid"
CGC_PID_FILE="$STATE_DIR/codegraph-watch.pid"
CGC_LOG_FILE="${CGC_LOG_FILE:-$STATE_DIR/codegraph-watch.log}"

BACKEND_HOST="${BACKEND_HOST:-127.0.0.1}"
BACKEND_PORT="${BACKEND_PORT:-8000}"
WEB_HOST="${WEB_HOST:-127.0.0.1}"
WEB_PORT="${WEB_PORT:-3000}"
CGC_WATCH="${CGC_WATCH:-1}"
CGC_DATABASE="${CGC_DATABASE:-falkordb}"
CGC_WATCH_PATH="${CGC_WATCH_PATH:-$ROOT_DIR}"
KG_MEMORY_SYNC="${KG_MEMORY_SYNC:-1}"
KG_MEMORY_SYNC_MODE="${KG_MEMORY_SYNC_MODE:-auto}"
KG_MEMORY_FILE="${KG_MEMORY_FILE:-$ROOT_DIR/.context/operations/kg_memory.jsonl}"
KG_SEED_SCRIPT="$ROOT_DIR/scripts/seed_kg_memory.py"
DB_BACKUP_BEFORE_DESTRUCTIVE="${DB_BACKUP_BEFORE_DESTRUCTIVE:-1}"
DB_BACKUP_DIR="${DB_BACKUP_DIR:-$ROOT_DIR/.backups/db}"
AUTO_INSTALL_BACKEND_DEPS="${AUTO_INSTALL_BACKEND_DEPS:-1}"
AUTO_FIX_BROKEN_DB_SCHEMA="${AUTO_FIX_BROKEN_DB_SCHEMA:-1}"
ALLOW_DB_SCHEMA_RESET="${ALLOW_DB_SCHEMA_RESET:-1}"
CONFIRM_DB_RESET="${CONFIRM_DB_RESET:-YES_I_UNDERSTAND_DATA_LOSS}"
HEALTH_WAIT_SECONDS="${HEALTH_WAIT_SECONDS:-60}"
HEALTH_POLL_INTERVAL="${HEALTH_POLL_INTERVAL:-10}"

if [[ "$CGC_WATCH_PATH" != /* ]]; then
  CGC_WATCH_PATH="$ROOT_DIR/$CGC_WATCH_PATH"
fi

if [[ "$CGC_LOG_FILE" != /* ]]; then
  CGC_LOG_FILE="$ROOT_DIR/$CGC_LOG_FILE"
fi

if [[ "$KG_MEMORY_FILE" != /* ]]; then
  KG_MEMORY_FILE="$ROOT_DIR/$KG_MEMORY_FILE"
fi

mkdir -p "$STATE_DIR"

install_backend_requirements() {
  echo "[run] Installing backend dependencies from requirements-dev.txt..."
  python3 -m pip install -r "$BACKEND_DIR/requirements-dev.txt"
}

ensure_docker_daemon() {
  DOCKER_ENSURE_PREFIX="[run]" DOCKER_STARTUP_TIMEOUT="${DOCKER_STARTUP_TIMEOUT:-90}" \
    "$ROOT_DIR/scripts/ensure-docker.sh"
}

require_cmd() {
  local cmd="$1"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "[run] Missing command: $cmd"
    exit 1
  fi
}

require_cmd docker
require_cmd python3
require_cmd npm
require_cmd lsof
require_cmd pgrep

kill_listening_on_port() {
  local port="$1"
  local label="$2"
  local pids

  pids="$(lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true)"
  if [[ -z "$pids" ]]; then
    return
  fi

  echo "[run] Port $port ($label) is busy. Stopping process(es): $pids"
  for pid in $pids; do
    kill "$pid" 2>/dev/null || true
  done

  sleep 1

  pids="$(lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true)"
  if [[ -z "$pids" ]]; then
    return
  fi

  echo "[run] Force stopping process(es) on port $port: $pids"
  for pid in $pids; do
    kill -9 "$pid" 2>/dev/null || true
  done
}

kill_pid_from_file() {
  local pid_file="$1"
  local label="$2"
  local pid

  if [[ ! -f "$pid_file" ]]; then
    return
  fi

  pid="$(cat "$pid_file" 2>/dev/null || true)"
  rm -f "$pid_file"

  if [[ -z "$pid" ]] || ! [[ "$pid" =~ ^[0-9]+$ ]]; then
    return
  fi

  if ! kill -0 "$pid" 2>/dev/null; then
    return
  fi

  echo "[run] Found stale $label process from previous run: $pid. Stopping..."
  kill "$pid" 2>/dev/null || true
  sleep 1

  if kill -0 "$pid" 2>/dev/null; then
    echo "[run] Force stopping stale $label process: $pid"
    kill -9 "$pid" 2>/dev/null || true
  fi
}

kill_matching_processes() {
  local pattern="$1"
  local label="$2"
  local pids

  pids="$(pgrep -f "$pattern" || true)"
  if [[ -z "$pids" ]]; then
    return
  fi

  echo "[run] Found stale $label process(es): $pids. Stopping..."
  for pid in $pids; do
    kill "$pid" 2>/dev/null || true
  done
  sleep 1
  for pid in $pids; do
    if kill -0 "$pid" 2>/dev/null; then
      echo "[run] Force stopping stale $label process: $pid"
      kill -9 "$pid" 2>/dev/null || true
    fi
  done
}

kill_codegraph_watch_for_path() {
  local watch_path="$1"
  local pids

  pids="$(ps -ax -o pid= -o command= | awk -v p="$watch_path" 'index($0, "codegraphcontext watch") && index($0, p) {print $1}')"
  if [[ -z "$pids" ]]; then
    return
  fi

  echo "[run] Found existing CodeGraphContext watcher(s) for $watch_path: $pids. Stopping..."
  for pid in $pids; do
    kill "$pid" 2>/dev/null || true
  done
  sleep 1
  for pid in $pids; do
    if kill -0 "$pid" 2>/dev/null; then
      echo "[run] Force stopping CodeGraphContext watcher: $pid"
      kill -9 "$pid" 2>/dev/null || true
    fi
  done
}

cleanup_stale_processes() {
  kill_listening_on_port "$BACKEND_PORT" "backend"
  if [[ "$WEB_PORT" != "$BACKEND_PORT" ]]; then
    kill_listening_on_port "$WEB_PORT" "web"
  fi

  kill_pid_from_file "$BACKEND_PID_FILE" "backend"
  kill_pid_from_file "$WEB_PID_FILE" "web"
  kill_pid_from_file "$CGC_PID_FILE" "codegraphcontext-watch"
  kill_matching_processes "uvicorn app.main:app" "backend"
  kill_matching_processes "next dev -- --hostname" "web"
  kill_matching_processes "next dev --hostname" "web"

  if [[ "$CGC_WATCH" == "1" ]]; then
    if [[ ! -d "$CGC_WATCH_PATH" ]]; then
      echo "[run] CGC_WATCH_PATH does not exist: $CGC_WATCH_PATH"
      exit 1
    fi
    kill_codegraph_watch_for_path "$CGC_WATCH_PATH"
  fi
}

has_newer_context_than_memory() {
  if [[ ! -f "$KG_MEMORY_FILE" ]]; then
    return 0
  fi

  if [[ -f "$ROOT_DIR/Claude.md" ]] && [[ "$ROOT_DIR/Claude.md" -nt "$KG_MEMORY_FILE" ]]; then
    return 0
  fi

  if [[ "$KG_SEED_SCRIPT" -nt "$KG_MEMORY_FILE" ]]; then
    return 0
  fi

  if [[ -d "$ROOT_DIR/.context" ]]; then
    local newer
    newer="$(find "$ROOT_DIR/.context" -type f -name '*.md' -newer "$KG_MEMORY_FILE" -print -quit 2>/dev/null || true)"
    if [[ -n "$newer" ]]; then
      return 0
    fi
  fi

  return 1
}

sync_knowledge_memory_if_needed() {
  if [[ "$KG_MEMORY_SYNC" != "1" ]]; then
    return
  fi

  if [[ ! -f "$KG_SEED_SCRIPT" ]]; then
    echo "[run] KG memory seed script not found: $KG_SEED_SCRIPT"
    echo "[run] Skipping knowledge-memory sync."
    return
  fi

  local should_sync=0
  case "$KG_MEMORY_SYNC_MODE" in
    force)
      should_sync=1
      ;;
    auto)
      if has_newer_context_than_memory; then
        should_sync=1
      fi
      ;;
    *)
      echo "[run] Unknown KG_MEMORY_SYNC_MODE='$KG_MEMORY_SYNC_MODE'. Expected: auto|force"
      exit 1
      ;;
  esac

  if [[ "$should_sync" -eq 0 ]]; then
    echo "[run] Knowledge memory is up to date."
    return
  fi

  echo "[run] Syncing knowledge-memory graph ($KG_MEMORY_SYNC_MODE)..."
  if python3 "$KG_SEED_SCRIPT" --project-root "$ROOT_DIR" --memory-file "$KG_MEMORY_FILE" --replace; then
    echo "[run] Knowledge-memory sync completed."
  else
    echo "[run] Knowledge-memory sync failed. Continuing startup."
  fi
}

db_has_required_tables() {
  (
    cd "$BACKEND_DIR"
    if [[ -n "${APP_DATABASE_URL:-}" ]]; then
      APP_DATABASE_URL="$APP_DATABASE_URL" PYTHONPATH=. python3 scripts/db_schema_health.py >/dev/null
    else
      PYTHONPATH=. python3 scripts/db_schema_health.py >/dev/null
    fi
  )
}

reset_db_public_schema() {
  if [[ "$ALLOW_DB_SCHEMA_RESET" != "1" ]]; then
    echo "[run] Refusing destructive DB reset (DROP SCHEMA public)."
    echo "[run] To force reset set ALL THREE variables:"
    echo "[run]   AUTO_FIX_BROKEN_DB_SCHEMA=1 ALLOW_DB_SCHEMA_RESET=1 CONFIRM_DB_RESET=YES_I_UNDERSTAND_DATA_LOSS ./run"
    return 1
  fi

  if [[ "$CONFIRM_DB_RESET" != "YES_I_UNDERSTAND_DATA_LOSS" ]]; then
    echo "[run] Destructive DB reset requires explicit confirmation."
    echo "[run] Set CONFIRM_DB_RESET=YES_I_UNDERSTAND_DATA_LOSS to proceed."
    return 1
  fi

  (
    cd "$BACKEND_DIR"
    if [[ -n "${APP_DATABASE_URL:-}" ]]; then
      APP_DATABASE_URL="$APP_DATABASE_URL" \
        ALLOW_LOCAL_SCHEMA_REPAIR=1 \
        DB_BACKUP_BEFORE_DESTRUCTIVE="$DB_BACKUP_BEFORE_DESTRUCTIVE" \
        DB_BACKUP_DIR="$DB_BACKUP_DIR" \
        PYTHONPATH=. \
        python3 scripts/repair_local_db_schema.py --allow-repair
    else
      ALLOW_LOCAL_SCHEMA_REPAIR=1 \
        DB_BACKUP_BEFORE_DESTRUCTIVE="$DB_BACKUP_BEFORE_DESTRUCTIVE" \
        DB_BACKUP_DIR="$DB_BACKUP_DIR" \
        PYTHONPATH=. \
        python3 scripts/repair_local_db_schema.py --allow-repair
    fi
  )
}

ensure_backend_schema() {
  echo "[run] Applying backend migrations..."
  (cd "$BACKEND_DIR" && python3 -m alembic upgrade head)

  if db_has_required_tables >/dev/null 2>&1; then
    echo "[run] Database schema check passed."
    return
  fi

  echo "[run] Database schema is inconsistent (missing required tables)."
  if [[ "$AUTO_FIX_BROKEN_DB_SCHEMA" != "1" ]]; then
    echo "[run] Auto-fix is disabled (AUTO_FIX_BROKEN_DB_SCHEMA=0)."
    echo "[run] Refusing to continue in non-working state."
    echo "[run] Manual fix: cd backend && PYTHONPATH=. python3 -m alembic upgrade head"
    exit 1
  fi

  echo "[run] Auto-fix requested for inconsistent schema."
  echo "[run] WARNING: destructive reset is blocked by default."
  if ! reset_db_public_schema; then
    echo "[run] Automatic repair aborted to protect data."
    echo "[run] Non-destructive options:"
    echo "[run]   cd backend && python3 -m alembic current"
    echo "[run]   cd backend && python3 -m alembic upgrade head"
    exit 1
  fi
  (cd "$BACKEND_DIR" && python3 -m alembic upgrade head)

  if db_has_required_tables >/dev/null 2>&1; then
    echo "[run] Database schema repaired successfully."
  else
    echo "[run] Failed to repair database schema automatically."
    exit 1
  fi
}

wait_for_http_ready() {
  local label="$1"
  local url="$2"
  local timeout_seconds="$3"
  local elapsed=0

  echo -n "[run] Waiting for $label"
  while [[ "$elapsed" -lt "$timeout_seconds" ]]; do
    if curl -fsS "$url" >/dev/null 2>&1; then
      echo " ready"
      return 0
    fi
    echo -n "."
    sleep 1
    elapsed=$((elapsed + 1))
  done

  echo ""
  echo "[run] $label did not become ready within ${timeout_seconds}s: $url"
  return 1
}

http_is_ready() {
  local url="$1"
  curl -fsS "$url" >/dev/null 2>&1
}

print_access_urls() {
  local backend_url="http://$BACKEND_HOST:$BACKEND_PORT/api/v1/health"
  local web_url="http://$WEB_HOST:$WEB_PORT"

  echo "[run] Startup summary"
  echo "[run] Web:     $web_url"
  echo "[run] Backend: $backend_url"

  local lan_ips=()
  local iface
  for iface in en0 en1 en2 en3 en4; do
    local ip
    ip="$(ipconfig getifaddr "$iface" 2>/dev/null || true)"
    if [[ -n "$ip" ]]; then
      lan_ips+=("$ip")
    fi
  done

  if [[ "${#lan_ips[@]}" -gt 0 ]]; then
    echo "[run] LAN access:"
    local seen=""
    local ip
    for ip in "${lan_ips[@]}"; do
      if [[ " $seen " == *" $ip "* ]]; then
        continue
      fi
      seen="$seen $ip"
      echo "[run]   Web:     http://$ip:$WEB_PORT"
      echo "[run]   Backend: http://$ip:$BACKEND_PORT/api/v1/health"
    done
  fi

  if [[ -n "${CGC_PID:-}" ]]; then
    echo "[run] CGC:     watching $CGC_WATCH_PATH"
  fi
  echo "[run] Press Ctrl+C to stop"
}

if ! ensure_docker_daemon; then
  exit 1
fi

if ! python3 -c "import uvicorn, alembic" >/dev/null 2>&1; then
  if [[ "$AUTO_INSTALL_BACKEND_DEPS" == "1" ]]; then
    install_backend_requirements
  else
    echo "[run] Python dependencies are missing."
    echo "[run] Install with: python3 -m pip install -r $BACKEND_DIR/requirements-dev.txt"
    exit 1
  fi
fi

if ! python3 -c "from fastapi.dependencies.utils import ensure_multipart_is_installed; ensure_multipart_is_installed()" >/dev/null 2>&1; then
  if [[ "$AUTO_INSTALL_BACKEND_DEPS" == "1" ]]; then
    echo "[run] Fixing multipart support for FastAPI..."
    python3 -m pip install "python-multipart>=0.0.9,<1.0"
  else
    echo "[run] FastAPI multipart support is missing in current Python environment."
    echo "[run] Install with: python3 -m pip install 'python-multipart>=0.0.9,<1.0'"
    exit 1
  fi
fi

if [[ ! -d "$WEB_DIR/node_modules" ]]; then
  echo "[run] Installing web dependencies..."
  (cd "$WEB_DIR" && npm install)
fi

if [[ ! -f "$WEB_DIR/package.json" ]]; then
  echo "[run] Frontend directory is invalid: $WEB_DIR"
  echo "[run] Set WEB_DIR_NAME=web-admin or WEB_DIR_NAME=web and retry."
  exit 1
fi

echo "[run] Cleaning stale local dev processes..."
cleanup_stale_processes

sync_knowledge_memory_if_needed

echo "[run] Starting PostgreSQL container..."
docker compose -f "$COMPOSE_FILE" up -d postgres >/dev/null

CONTAINER_ID="$(docker compose -f "$COMPOSE_FILE" ps -q postgres)"
if [[ -n "$CONTAINER_ID" ]]; then
  echo -n "[run] Waiting for PostgreSQL"
  for _ in $(seq 1 40); do
    HEALTH="$(docker inspect --format='{{if .State.Health}}{{.State.Health.Status}}{{else}}running{{end}}' "$CONTAINER_ID" 2>/dev/null || true)"
    if [[ "$HEALTH" == "healthy" ]] || [[ "$HEALTH" == "running" ]]; then
      echo " ready"
      break
    fi
    echo -n "."
    sleep 1
  done
fi

ensure_backend_schema

cleanup() {
  local code=$?
  trap - INT TERM EXIT

  if [[ -n "${BACKEND_PID:-}" ]] && kill -0 "$BACKEND_PID" 2>/dev/null; then
    kill "$BACKEND_PID" 2>/dev/null || true
  fi

  if [[ -n "${WEB_PID:-}" ]] && kill -0 "$WEB_PID" 2>/dev/null; then
    kill "$WEB_PID" 2>/dev/null || true
  fi

  if [[ -n "${CGC_PID:-}" ]] && kill -0 "$CGC_PID" 2>/dev/null; then
    kill "$CGC_PID" 2>/dev/null || true
  fi

  wait "${BACKEND_PID:-}" 2>/dev/null || true
  wait "${WEB_PID:-}" 2>/dev/null || true
  wait "${CGC_PID:-}" 2>/dev/null || true
  rm -f "$BACKEND_PID_FILE" "$WEB_PID_FILE" "$CGC_PID_FILE"

  echo "[run] Dev processes stopped."
  exit "$code"
}
trap cleanup INT TERM EXIT

echo "[run] Starting backend on http://$BACKEND_HOST:$BACKEND_PORT"
(
  cd "$BACKEND_DIR"
  python3 -m uvicorn app.main:app --host "$BACKEND_HOST" --port "$BACKEND_PORT" --reload
) &
BACKEND_PID=$!
echo "$BACKEND_PID" >"$BACKEND_PID_FILE"

echo "[run] Starting web app ($WEB_DIR_NAME) on http://$WEB_HOST:$WEB_PORT"
(
  cd "$WEB_DIR"
  npm run dev -- --hostname "$WEB_HOST" --port "$WEB_PORT"
) &
WEB_PID=$!
echo "$WEB_PID" >"$WEB_PID_FILE"

if [[ "$CGC_WATCH" == "1" ]]; then
  if python3 -m codegraphcontext --version >/dev/null 2>&1; then
    echo "[run] Starting CodeGraphContext watch on $CGC_WATCH_PATH (database: $CGC_DATABASE)"
    echo "[run] CGC logs: $CGC_LOG_FILE"
    (
      cd "$ROOT_DIR"
      python3 -m codegraphcontext --database "$CGC_DATABASE" watch "$CGC_WATCH_PATH" >>"$CGC_LOG_FILE" 2>&1
    ) &
    CGC_PID=$!
    echo "$CGC_PID" >"$CGC_PID_FILE"
  else
    echo "[run] CodeGraphContext is not installed. Skipping watcher."
    echo "[run] Install with: python3 -m pip install codegraphcontext"
  fi
fi

if ! wait_for_http_ready "backend" "http://$BACKEND_HOST:$BACKEND_PORT/api/v1/health" "$HEALTH_WAIT_SECONDS"; then
  exit 1
fi

if ! wait_for_http_ready "web" "http://$WEB_HOST:$WEB_PORT" "$HEALTH_WAIT_SECONDS"; then
  exit 1
fi

print_access_urls

while true; do
  if ! http_is_ready "http://$BACKEND_HOST:$BACKEND_PORT/api/v1/health"; then
    echo "[run] Backend health check failed after startup."
    exit 1
  fi

  if ! http_is_ready "http://$WEB_HOST:$WEB_PORT"; then
    echo "[run] Web admin health check failed after startup."
    exit 1
  fi

  if [[ -n "${CGC_PID:-}" ]] && ! kill -0 "$CGC_PID" 2>/dev/null; then
    echo "[run] CodeGraphContext watcher exited. Continuing without watcher."
    wait "$CGC_PID" || true
    rm -f "$CGC_PID_FILE"
    CGC_PID=""
  fi

  sleep "$HEALTH_POLL_INTERVAL"
done
