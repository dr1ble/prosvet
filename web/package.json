{
  "name": "web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "verify:styles": "node scripts/verify-style-contract.mjs",
    "lint": "npm run verify:styles && eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:staged": "lint-staged"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.564.0",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "^10.4.24",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "lint-staged": "latest",
    "postcss": "^8.5.6",
    "prettier": "latest",
    "puppeteer": "^24.37.2",
    "tailwindcss": "^4.1.18",
    "typescript": "latest"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  }
